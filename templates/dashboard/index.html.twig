{% extends 'base.html.twig' %}

{% block title %}Dashboard - Momentary{% endblock %}

{% block body %}
    <div class="container pb-5">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="fw-bold mb-0">Dashboard</h1>
                <p class="text-muted">Video-Intelligence & Pipeline Control</p>
            </div>
            <a href="{{ path('video_new') }}" class="btn btn-primary shadow-sm rounded-pill px-4">
                <i class="fas fa-plus me-2"></i>Neues Video scannen
            </a>
        </div>

        <!-- Kompakt-Stats -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="card h-100 bg-white">
                    <div class="card-body py-3">
                        <div class="text-muted small fw-bold text-uppercase">Videos</div>
                        <div class="h4 mb-0 fw-bold">{{ stats.videos }}</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card h-100 bg-white">
                    <div class="card-body py-3">
                        <div class="text-muted small fw-bold text-uppercase">Personen</div>
                        <div class="h4 mb-0 fw-bold">{{ stats.persons }}</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card h-100 bg-white">
                    <div class="card-body py-3">
                        <div class="text-muted small fw-bold text-uppercase">Identifiziert</div>
                        <div class="h4 mb-0 fw-bold text-success">{{ stats.identified }}</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card h-100 bg-white border-left-warning shadow-sm">
                    <div class="card-body py-3">
                        <div class="text-muted small fw-bold text-uppercase">Auftrennen</div>
                        <div class="h4 mb-0 fw-bold text-warning">{{ stats.to_reassign }}</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- HAUPTSPALTEN: VIDEO PIPELINE -->
            <div class="col-lg-8">
                <div class="card h-100">
                    <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold mb-0"><i class="fas fa-microchip me-2 text-primary"></i>Aktuelle Pipeline</h5>
                        <a href="{{ path('app_video_index') }}" class="btn btn-sm btn-outline-primary rounded-pill px-3">Alle Videos</a>
                    </div>
                    <div class="card-body px-4">
                        <div class="row g-3">
                                {% for video in recent_videos %}
                                    {% set statusInfo = {
                                        'pending': {'color': 'secondary', 'icon': 'clock'},
                                        'downloading': {'color': 'info', 'icon': 'download'},
                                        'scene_detection': {'color': 'warning', 'icon': 'cut'},
                                        'splitting': {'color': 'primary', 'icon': 'film'},
                                        'analyzing_faces': {'color': 'dark', 'icon': 'user-search'},
                                        'optimizing': {'color': 'info', 'icon': 'magic'},
                                        'completed': {'color': 'success', 'icon': 'check-circle'},
                                        'error': {'color': 'danger', 'icon': 'exclamation-triangle'}
                                    }[video.status.value] ?? {'color': 'secondary', 'icon': 'question'} %}

                                    <div class="col-12">
                                        <div class="card border-0 bg-light bg-opacity-50">
                                            <div class="card-body p-2">
                                                <div class="row g-3 align-items-center">
                                                    <div class="col-auto">
                                                        <div class="position-relative bg-white rounded overflow-hidden shadow-sm" style="width: 100px; height: 60px;">
                                                            {% if video.thumbnailUrl %}
                                                                <img src="{{ imgproxy_url(video.thumbnailUrl, 100, 60) }}" alt="{{ video.title }}" class="w-100 h-100 object-fit-cover position-absolute top-0 start-0">
                                                            {% endif %}
                                                            <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-{{ statusInfo.color }} bg-opacity-25" style="z-index: 1;">
                                                                <i class="fas fa-{{ statusInfo.icon }} text-white shadow-sm" style="font-size: 0.8rem;"></i>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col">
                                                        <div class="fw-bold text-dark text-truncate small" title="{{ video.title }}">{{ video.title }}</div>
                                                        <div class="d-flex align-items-center gap-2">
                                                            <span class="badge rounded-pill bg-{{ statusInfo.color }} bg-opacity-10 text-{{ statusInfo.color }} border border-{{ statusInfo.color }} px-1 py-0" style="font-size: 0.6rem;">
                                                                {{ video.status.value|upper }}
                                                            </span>
                                                            {% if video.youtubeUrl %}
                                                                <span class="text-muted text-truncate" style="font-size: 0.65rem;">
                                                                    <i class="fab fa-youtube text-danger me-1"></i> {{ video.youtubeUrl|slice(0, 30) }}...
                                                                </span>
                                                            {% endif %}
                                                        </div>
                                                    </div>
                                                    <div class="col-auto">
                                                        <div class="btn-group btn-group-sm shadow-sm rounded">
                                                            <a href="{{ path('app_video_show', {id: video.id}) }}" class="btn btn-white px-2" title="Details">
                                                                <i class="fas fa-eye text-primary"></i>
                                                            </a>
                                                            <a href="{{ path('video_timeline', {id: video.id}) }}" class="btn btn-white px-2" title="Timeline">
                                                                <i class="fas fa-stream text-primary"></i>
                                                            </a>
                                                            <form method="post" action="{{ path('video_delete', {id: video.id}) }}" onsubmit="return confirm('Soll dieses Video wirklich gelöscht werden?');" class="d-inline">
                                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ video.id) }}">
                                                                <button class="btn btn-white px-2 text-danger" title="Löschen">
                                                                    <i class="fas fa-trash-alt"></i>
                                                                </button>
                                                            </form>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                {% else %}
                                    <div class="col-12 text-center py-4 text-muted small">Keine aktuellen Videos.</div>
                                {% endfor %}
                            </div>
                    </div>
                </div>
            </div>

            <!-- NEBENSPALTE: PERSONEN & SCHNELLZUGRIFF -->
            <div class="col-lg-4">
                <div class="row g-2 mb-4">
                    <div class="col-6 col-sm-3 col-lg-6">
                        <a href="{{ path('person_index') }}" class="btn btn-light border shadow-sm w-100 py-3 hover-card">
                            <i class="fas fa-users d-block mb-2 text-primary"></i>
                            <span class="small fw-bold">Personen</span>
                        </a>
                    </div>
                    <div class="col-6 col-sm-3 col-lg-6">
                        <a href="{{ path('app_identity_resolve') }}" class="btn btn-light border shadow-sm w-100 py-3 hover-card">
                            <i class="fas fa-wand-magic-sparkles d-block mb-2 text-warning"></i>
                            <span class="small fw-bold">Resolve</span>
                        </a>
                    </div>
                    <div class="col-6 col-sm-3 col-lg-6">
                        <a href="{{ path('app_identity_quick_resolve') }}" class="btn btn-light border shadow-sm w-100 py-3 hover-card">
                            <i class="fas fa-bolt d-block mb-2 text-info"></i>
                            <span class="small fw-bold">Quick</span>
                        </a>
                    </div>
                    <div class="col-6 col-sm-3 col-lg-6">
                        <a href="{{ path('app_identity_tinder_resolve') }}" class="btn btn-light border shadow-sm w-100 py-3 hover-card">
                            <i class="fas fa-fire d-block mb-2 text-danger"></i>
                            <span class="small fw-bold">Tinder</span>
                        </a>
                    </div>
                    <div class="col-6 col-sm-3 col-lg-6">
                        <a href="{{ path('app_identity_reassign_faces') }}" class="btn btn-light border shadow-sm w-100 py-3 hover-card">
                            <i class="fas fa-scissors d-block mb-2 text-warning"></i>
                            <span class="small fw-bold">Auftrennen</span>
                        </a>
                    </div>
                    <div class="col-6 col-sm-3 col-lg-6">
                        <form action="{{ path('person_cleanup') }}" method="POST" onsubmit="return confirm('Sollen wirklich alle Personen ohne Sichtungen gelöscht werden?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('person_cleanup') }}">
                            <button type="submit" class="btn btn-light border shadow-sm w-100 py-3 hover-card">
                                <i class="fas fa-broom d-block mb-2 text-danger"></i>
                                <span class="small fw-bold">Cleanup</span>
                            </button>
                        </form>
                    </div>
                    <div class="col-12 mt-2">
                        <a href="{{ path('app_video_index') }}" class="btn btn-primary shadow-sm w-100 py-3 hover-card">
                            <i class="fas fa-upload d-block mb-2"></i>
                            <span class="small fw-bold text-white">Video Übersicht</span>
                        </a>
                    </div>
                </div>

                <!-- Zuletzt identifiziert -->
                <div class="card">
                    <div class="card-header bg-white border-0 pt-4 px-4">
                        <h6 class="fw-bold mb-0">Zuletzt identifiziert</h6>
                    </div>
                    <div class="card-body px-4 pb-4">
                        <div class="list-group list-group-flush">
                            {% for person in recent_persons %}
                                {% set displayFace = person.profileFace ?: person.videoFaces|first %}
                                <a href="{{ path('person_detail', {id: person.id}) }}" class="list-group-item list-group-item-action border-0 px-0 d-flex align-items-center mb-2">
                                    <div class="rounded-circle shadow-sm me-3 border border-2 border-white overflow-hidden flex-shrink-0" style="width: 38px; height: 38px; background-color: #f8f9fa;">
                                        {% if displayFace %}
                                            <div style="{{ face_zoom_style(imgproxy_url(displayFace.faceImagePath), displayFace.boundingBox, 0.1) }}"></div>
                                        {% else %}
                                            <div class="d-flex align-items-center justify-content-center h-100 text-muted small fw-bold">{{ person.name|slice(0,1)|upper }}</div>
                                        {% endif %}
                                    </div>
                                    <div class="flex-grow-1 overflow-hidden">
                                        <div class="small fw-bold text-dark text-truncate">{{ person.name }}</div>
                                        <div class="text-muted" style="font-size: 0.7rem;">{{ person.videoFaces|length }} Sichtungen</div>
                                    </div>
                                </a>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .btn-white { background: #fff; border: 1px solid #dee2e6; }
        .btn-white:hover { background: #f8f9fa; }
        .badge { font-weight: 600; letter-spacing: 0.3px; }
        .list-group-item-action { transition: background 0.2s; }
        .list-group-item-action:hover { background: #f1f5f9 !important; border-radius: 8px !important; }
    </style>
{% endblock %}