<div {{ attributes.defaults({ class: 'scene-section mb-4' }) }}>
    {# KAPITEL ANZEIGE #}
    {% set chapter = null %}
    {% for c in scene.video.chapters %}
        {% if scene.startSeconds >= c.startSeconds and scene.endSeconds <= c.endSeconds %}
            {% set chapter = c %}
        {% endif %}
    {% endfor %}

    {% if chapter and scene.startSeconds == chapter.startSeconds %}
        <div class="chapter-indicator mb-2 d-flex align-items-center">
            <div class="chapter-line flex-grow-1" style="height: 4px; background: #0d6efd; opacity: 0.4; border-radius: 2px 0 0 2px;"></div>
            <span class="badge rounded-pill bg-primary px-3 shadow-sm mx-2 d-flex align-items-center" style="font-size: 0.9rem;">
                <i class="fas fa-bookmark me-2"></i> Kapitel: {{ chapter.title }}
            </span>
            <div class="chapter-line flex-grow-1" style="height: 4px; background: #0d6efd; opacity: 0.4; border-radius: 0 2px 2px 0;"></div>
        </div>
    {% endif %}

    <div class="card border-0 shadow-sm" style="border-radius: 12px; position: relative;">
        <div class="card-header bg-white p-3 d-flex justify-content-between align-items-center" style="border-radius: 12px 12px 0 0; position: relative;">

            <div class="d-flex align-items-center flex-grow-1">
                <div class="scene-badge me-3 shadow-sm">{{ sceneNumber }}</div>
                <div class="flex-grow-1">
                    {# INPUT FÜR DEN TITEL #}
                    <input type="text"
                           class="form-control form-control-sm border-0 fw-bold p-0 bg-transparent mb-0"
                           style="box-shadow: none; font-size: 1rem;"
                           placeholder="Szene {{ sceneNumber }} benennen..."
                           data-model="scene.title"
                           data-action="blur->live#action"
                           data-live-action-param="updateTitle">

                    <small class="text-muted font-monospace" style="font-size: 0.75rem;">
                        <i class="far fa-clock me-1"></i>{{ scene.startSeconds|round(1) }}s - {{ scene.endSeconds|round(1) }}s
                        <span class="ms-1 text-primary">({{ this.duration }}s)</span>
                    </small>

                    {# TAGS ANZEIGE #}
                    <div class="mt-2">
                        {% for tag in scene.tags %}
                            <span class="badge rounded-pill border text-dark me-1" 
                                  style="background-color: {{ tag.category.color }}33; border-color: {{ tag.category.color }} !important; font-size: 0.7rem;">
                                {{ tag.name }}
                            </span>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <div class="d-flex align-items-center gap-2">
                {# TAG ZUWEISUNG #}
                <div class="dropdown" style="position: static;">
                    <button class="btn btn-sm btn-outline-info dropdown-toggle py-0 px-2" type="button" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                        <i class="fas fa-tags me-1"></i> Tags
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="min-width: 250px; max-height: 400px; overflow-y: auto;">
                        <li><h6 class="dropdown-header">Szene taggen</h6></li>
                        {% for category in this.categories %}
                            <li><hr class="dropdown-divider"></li>
                            <li><h6 class="dropdown-header d-flex align-items-center">
                                <span class="badge me-2" style="background-color: {{ category.color }}; width: 10px; height: 10px; padding: 0;">&nbsp;</span>
                                {{ category.name }}
                            </h6></li>
                            {% for tag in category.tags %}
                                <li>
                                    <button class="dropdown-item d-flex justify-content-between align-items-center" 
                                            data-action="live#action" 
                                            data-live-action-param="toggleTag"
                                            data-live-tagId-param="{{ tag.id }}">
                                        <span>{{ tag.name }}</span>
                                        {% if scene.tags.contains(tag) %}
                                            <i class="fas fa-check-circle text-info ms-2"></i>
                                        {% else %}
                                            <i class="far fa-circle text-muted ms-2" style="opacity: 0.3;"></i>
                                        {% endif %}
                                    </button>
                                </li>
                            {% endfor %}
                        {% endfor %}
                        {% if this.categories|length == 0 %}
                            <li><span class="dropdown-item-text text-muted small italic text-center d-block">Keine Kategorien definiert.</span></li>
                        {% endif %}
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item small text-center text-primary" href="#tag-manager" onclick="document.getElementById('tag-manager').scrollIntoView({behavior: 'smooth'})">
                                <i class="fas fa-cog me-1"></i> Tag-Manager
                            </a>
                        </li>
                    </ul>
                </div>

                {# KAPITEL ZUWEISUNG #}
                <div class="dropdown" style="position: static;">
                    <button class="btn btn-sm btn-outline-primary dropdown-toggle py-0 px-2" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fas fa-bookmark me-1"></i> Kapitel
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                        <li><h6 class="dropdown-header">Zu Kapitel hinzufügen</h6></li>
                        {% for c in this.chapters %}
                            <li>
                                <button class="dropdown-item d-flex justify-content-between align-items-center" 
                                        data-action="live#action" 
                                        data-live-action-param="assignToChapter"
                                        data-live-assignToChapterId-param="{{ c.id }}">
                                    <span>{{ c.title }}</span>
                                    {% if chapter and chapter.id == c.id %}
                                        <i class="fas fa-check text-success ms-2"></i>
                                    {% endif %}
                                </button>
                            </li>
                        {% endfor %}
                        {% if this.chapters|length == 0 %}
                            <li><span class="dropdown-item-text text-muted small italic">Keine Kapitel vorhanden</span></li>
                        {% endif %}
                        <li><hr class="dropdown-divider"></li>
                        <li class="px-3 py-2">
                            <div class="input-group input-group-sm mb-1">
                                <input type="text" 
                                       class="form-control" 
                                       placeholder="Neues Kapitel Name..."
                                       data-model="newChapterTitle">
                                <button class="btn btn-primary" 
                                        type="button"
                                        data-action="live#action"
                                        data-live-action-param="createChapterAndAssignFollowing">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </div>
                            <small class="text-muted" style="font-size: 0.65rem;">Erstellt Kapitel ab hier bis Ende</small>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item small" href="#chapter-manager" onclick="document.getElementById('chapter-manager').scrollIntoView({behavior: 'smooth'})">
                                <i class="fas fa-tasks me-1"></i> Kapitel-Manager öffnen
                            </a>
                        </li>
                    </ul>
                </div>

                {# MERGE BACKWARDS BUTTON #}
                {% if this.canMergeBackwards %}
                    <button class="btn btn-sm btn-outline-secondary py-0 px-2"
                            title="Alle leeren Szenen davor in die letzte Personen-Szene mergen"
                            data-action="live#action"
                            data-live-action-param="mergeEmptyBackwards"
                            onclick="return confirm('Alle leeren Szenen seit der letzten Personen-Szene mit dieser verschmelzen?')">
                        <i class="fas fa-level-up-alt fa-rotate-270 me-1"></i> Merge Up
                    </button>
                {% endif %}

                {# MERGE BUTTON #}
                <button class="btn btn-link text-muted p-1"
                        title="Mit nächster Szene zusammenfassen"
                        data-action="live#action"
                        data-live-action-param="mergeWithNext"
                        onclick="return confirm('Diese Szene mit der nächsten verschmelzen?')">
                    <i class="fas fa-object-group"></i>
                </button>

                {# VIDEO ANSEHEN BUTTON #}
                <a href="{{ path('app_video_show', {id: scene.video.id, t: scene.startSeconds|round(1)}) }}" 
                   class="btn btn-sm btn-outline-success py-0 px-2"
                   title="Szene im Video-Player ansehen">
                    <i class="fas fa-play me-1"></i> Video
                </a>

                <span class="badge rounded-pill {{ this.faces|length > 0 ? 'bg-primary' : 'bg-light text-muted' }} border"
                      data-bs-toggle="collapse"
                      data-bs-target="#scene-collapse-{{ scene.id }}"
                      style="cursor: pointer;">
                    {{ this.faces|length }} Gesichter
                </span>
                <i class="fas fa-chevron-down text-muted transition-icon" data-bs-toggle="collapse" data-bs-target="#scene-collapse-{{ scene.id }}"></i>
            </div>
        </div>

        <div class="collapse show" id="scene-collapse-{{ scene.id }}">
            <div class="card-body bg-light border-top p-3">
                {% if this.faces|length > 0 %}
                    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-6 g-3">
                        {% for videoFace in this.faces %}
                            <div class="col face-item-wrapper">
                                {{ component('FaceCardComponent', { videoFace: videoFace }) }}
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-center py-3">
                        <p class="text-muted small mb-0 italic">Keine Gesichter in dieser Szene.</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>