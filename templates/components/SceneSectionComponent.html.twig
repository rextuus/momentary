<div {{ attributes.defaults({ class: 'scene-section mb-4' }) }}>
    <div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 12px;">
        <div class="card-header bg-white p-3 d-flex justify-content-between align-items-center">

            <div class="d-flex align-items-center flex-grow-1">
                <div class="scene-badge me-3 shadow-sm">{{ sceneNumber }}</div>
                <div class="flex-grow-1">
                    {# INPUT FÜR DEN TITEL #}
                    <input type="text"
                           class="form-control form-control-sm border-0 fw-bold p-0 bg-transparent mb-0"
                           style="box-shadow: none; font-size: 1rem;"
                           placeholder="Szene {{ sceneNumber }} benennen..."
                           data-model="scene.title"
                           data-action="blur->live#action"
                           data-live-action-param="updateTitle">

                    <small class="text-muted font-monospace" style="font-size: 0.75rem;">
                        <i class="far fa-clock me-1"></i>{{ scene.startSeconds|round(1) }}s - {{ scene.endSeconds|round(1) }}s
                        <span class="ms-1 text-primary">({{ this.duration }}s)</span>
                    </small>
                </div>
            </div>

            <div class="d-flex align-items-center gap-2">
                {# MERGE BACKWARDS BUTTON #}
                {% if this.canMergeBackwards %}
                    <button class="btn btn-sm btn-outline-secondary py-0 px-2"
                            title="Alle leeren Szenen davor in die letzte Personen-Szene mergen"
                            data-action="live#action"
                            data-live-action-param="mergeEmptyBackwards"
                            onclick="return confirm('Alle leeren Szenen seit der letzten Personen-Szene mit dieser verschmelzen?')">
                        <i class="fas fa-level-up-alt fa-rotate-270 me-1"></i> Merge Up
                    </button>
                {% endif %}

                {# MERGE BUTTON #}
                <button class="btn btn-link text-muted p-1"
                        title="Mit nächster Szene zusammenfassen"
                        data-action="live#action"
                        data-live-action-param="mergeWithNext"
                        onclick="return confirm('Diese Szene mit der nächsten verschmelzen?')">
                    <i class="fas fa-object-group"></i>
                </button>

                <span class="badge rounded-pill {{ this.faces|length > 0 ? 'bg-primary' : 'bg-light text-muted' }} border"
                      data-bs-toggle="collapse"
                      data-bs-target="#scene-collapse-{{ scene.id }}"
                      style="cursor: pointer;">
                    {{ this.faces|length }} Gesichter
                </span>
                <i class="fas fa-chevron-down text-muted transition-icon" data-bs-toggle="collapse" data-bs-target="#scene-collapse-{{ scene.id }}"></i>
            </div>
        </div>

        <div class="collapse show" id="scene-collapse-{{ scene.id }}">
            <div class="card-body bg-light border-top p-3">
                {% if this.faces|length > 0 %}
                    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-6 g-3">
                        {% for videoFace in this.faces %}
                            <div class="col face-item-wrapper">
                                {{ component('FaceCardComponent', { videoFace: videoFace }) }}
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-center py-3">
                        <p class="text-muted small mb-0 italic">Keine Gesichter in dieser Szene.</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>