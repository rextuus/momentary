<div {{ attributes }} class="tinder-resolve-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0">Tinder-Identifizierung</h4>
        <span class="badge bg-secondary rounded-pill">Noch {{ this.remainingCount }} Personen</span>
    </div>

    <div class="card mb-4 shadow-sm border-0">
        <div class="card-body p-3">
            <h6 class="card-subtitle mb-2 text-muted small uppercase fw-bold">Status-Filter</h6>
            <div class="d-flex flex-wrap gap-2 mb-3">
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="checkbox" id="tinder_status_new" value="new" data-model="statuses[]" {% if 'new' in statuses %}checked{% endif %}>
                    <label class="form-check-label small" for="tinder_status_new">Neu</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="checkbox" id="tinder_status_wasted" value="wasted" data-model="statuses[]" {% if 'wasted' in statuses %}checked{% endif %}>
                    <label class="form-check-label small" for="tinder_status_wasted">Ausgeblendet</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="checkbox" id="tinder_status_unknown" value="unknown" data-model="statuses[]" {% if 'unknown' in statuses %}checked{% endif %}>
                    <label class="form-check-label small" for="tinder_status_unknown">Unbekannt</label>
                </div>
            </div>

        </div>
    </div>

    {% set person = this.person %}
    {% if person %}
        {% set displayFace = person.profileFace ?: person.videoFaces|first %}
        
        <div class="tinder-card-wrapper mx-auto" style="max-width: 500px;">
            <div class="card shadow-lg border-0 overflow-hidden mb-4 position-relative">
                {% set detectedPerson = null %}
                {% for face in person.videoFaces %}
                    {% if face.detection %}
                        {% set detectedPerson = face.detection %}
                    {% endif %}
                {% endfor %}

                {% if detectedPerson %}
                    <div class="bg-success text-white p-3 d-flex justify-content-between align-items-center animate__animated animate__fadeInDown" style="z-index: 20;">
                        <div class="me-2">
                            <i class="fas fa-magic me-2"></i> Ist das <strong>{{ detectedPerson.name }}</strong>?
                            <div class="small opacity-75">Gefunden via KI</div>
                        </div>
                        <button type="button" 
                                data-action="live#action" 
                                data-live-action-param="assignToDetectedPerson" 
                                data-live-person-id-param="{{ person.id }}" 
                                data-live-detected-person-id-param="{{ detectedPerson.id }}" 
                                class="btn btn-light btn-sm rounded-pill px-3 fw-bold shadow-sm">
                            <i class="fas fa-check me-1"></i> Ja
                        </button>
                    </div>
                {% endif %}

                <div class="card-img-top bg-dark position-relative overflow-hidden" style="aspect-ratio: 1/1; cursor: zoom-in;"
                     data-bs-toggle="modal"
                     data-bs-target="#imageModal"
                     data-bs-img="{{ imgproxy_url(displayFace.faceImagePath, 800, 600, 'fit') }}"
                     data-bs-box="{{ displayFace.boundingBoxStyles }}"
                     data-bs-caption="Sichtung in {{ displayFace.video.title }}">
                    {% if displayFace %}
                        <div class="position-absolute top-0 left-0 w-100 h-100" style="{{ face_zoom_style(imgproxy_url(displayFace.faceImagePath), displayFace.boundingBox, 0.2) }}"></div>
                        <div class="position-absolute border border-danger border-3" style="{{ displayFace.boundingBoxStyles|raw }}; pointer-events: none;"></div>
                    {% else %}
                        <div class="d-flex align-items-center justify-content-center h-100 text-white opacity-50">
                            <i class="fas fa-user-slash fa-5x"></i>
                        </div>
                    {% endif %}
                </div>
                
                <div class="card-body text-center bg-white p-4">
                    <h3 class="mb-1 text-dark">{{ person.videoFaces|length }} Sichtungen</h3>
                    <div class="progress mb-3" style="height: 8px; border-radius: 4px;">
                        <div class="progress-bar bg-info" role="progressbar" style="width: {{ person.showCount * 10 }}%" aria-valuenow="{{ person.showCount }}" aria-valuemin="0" aria-valuemax="10"></div>
                    </div>
                    <p class="text-muted small">Wurde bereits {{ person.showCount }} mal übersprungen.</p>
                </div>

                <!-- Swipe Buttons / Action Buttons -->
                <div class="d-flex justify-content-around p-4 border-top bg-light">
                    <!-- DISLIKE (Unknown) -->
                    <button data-action="live#action" data-live-action-param="markAsUnknown" class="btn btn-outline-danger btn-lg rounded-circle shadow-sm" style="width: 80px; height: 80px;">
                        <i class="fas fa-times fa-2x"></i>
                    </button>

                    <!-- SKIP (Next) -->
                    <button data-action="live#action" data-live-action-param="skip" class="btn btn-outline-secondary btn-lg rounded-circle shadow-sm" style="width: 60px; height: 60px; margin-top: 10px;">
                        <i class="fas fa-forward"></i>
                    </button>

                    <!-- LIKE (Identify) -->
                    <a href="{{ path('app_identity_resolve', {currentPersonId: person.id, fromTinder: 1}) }}" class="btn btn-success btn-lg rounded-circle shadow-lg d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                        <i class="fas fa-heart fa-2x"></i>
                    </a>
                </div>
            </div>
            
            <div class="text-center text-muted small mt-2">
                <p><i class="fas fa-info-circle me-1"></i> Klicke auf das Herz, um diese Person zu benennen. Klicke auf das X, wenn sie unbekannt ist.</p>
            </div>
        </div>
    {% else %}
        <div class="alert alert-info text-center py-5 shadow-sm border-0">
            <i class="fas fa-check-circle fa-4x mb-3 d-block text-success"></i>
            <h3>Alle Personen durchgesehen!</h3>
            <p class="mb-0">Es gibt keine weiteren Personen, die deinen Filterkriterien entsprechen.</p>
            <div class="mt-4">
                <button class="btn btn-primary" data-action="live#emit" data-event="refresh">Neu laden</button>
            </div>
        </div>
    {% endif %}

    <style>
        .tinder-card-wrapper {
            animation: fadeIn 0.3s ease-out;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .tinder-resolve-container .btn-lg {
            transition: transform 0.1s;
        }
        .tinder-resolve-container .btn-lg:active {
            transform: scale(0.9);
        }
    </style>

</div>
