<div {{ attributes }} class="card h-100 shadow-sm {% if not person.identified %}border-warning{% endif %}">
    {# Header mit Bild #}
    <div class="card-header bg-transparent border-0 text-center pt-4">
        <div class="position-relative d-inline-block">
            {% set firstFace = person.videoFaces|first %}

            {% if firstFace %}
                {# Der Pfad in der DB ist 'video_faces/uuid.jpg' #}
                {# Wir hängen den statischen Teil '/uploads/faces/' davor #}
                <img src="{{ asset('uploads/faces/' ~ firstFace.faceImagePath) }}"
                     class="rounded-circle border shadow-sm"
                     style="width: 100px; height: 100px; object-fit: cover;"
                     onerror="this.parentNode.innerHTML='<div class=\'rounded-circle bg-light d-flex align-items-center justify-content-center border\' style=\'width: 100px; height: 100px;\'>{{ person.name|slice(0, 2)|upper }}</div>'">
            {% else %}
                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center border"
                     style="width: 100px; height: 100px; font-size: 1.5rem; font-weight: bold; color: #666;">
                    {{ person.name|slice(0, 2)|upper }}
                </div>
            {% endif %}
        </div>
        <h5 class="mt-3 mb-0">{{ person.name }}</h5>
    </div>

    <div class="card-body">
        <div class="d-flex justify-content-between mb-3">
            <span class="badge bg-light text-dark border">
                <i class="fas fa-video me-1"></i> {{ person.videoFaces|length }} Faces
            </span>
            <span class="badge bg-light text-dark border">
                <i class="fas fa-venus-mars me-1"></i> {{ person.probablyGender|capitalize|default('Unknown') }}
            </span>
        </div>

        {# Merge Form #}
        <div class="bg-light p-3 rounded mb-3 border">
            <h6 class="small fw-bold mb-2 text-uppercase text-muted">Merge into another Person</h6>
            {{ form_start(form, {
                attr: {
                    'data-action': 'live#action:prevent',
                    'data-live-action-param': 'submit',
                }
            }) }}
            <div class="d-flex gap-2">
                <div class="flex-grow-1">
                    {{ form_widget(form.target, { attr: { 'class': 'form-select form-select-sm' } }) }}
                </div>
                <button type="submit" class="btn btn-sm btn-outline-primary">
                    <i class="fas fa-link"></i>
                </button>
            </div>
            {{ form_end(form) }}
        </div>

        <div class="d-grid gap-2">
            <a href="{{ path('person_detail', { id: person.id }) }}" class="btn btn-primary">
                <i class="fas fa-eye me-2"></i>View Details
            </a>

            <button class="btn btn-sm btn-link text-danger"
                    data-action="live#action"
                    data-live-action-param="wastePerson"
                    data-confirm="Are you sure you want to delete this person and all their face data?">
                <i class="fas fa-trash-alt me-1"></i> Delete Person
            </button>
        </div>
    </div>
</div>