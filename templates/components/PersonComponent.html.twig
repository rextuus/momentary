{# src/templates/components/PersonComponent.html.twig #}
<div {{ attributes }} class="card h-100 shadow-sm border-0 overflow-hidden">
    {# Header mit Zoom-Profilbild als Link #}
    <div class="card-header bg-transparent border-0 text-center pt-4">
        {# WICHTIG: Wir holen uns das aktuelle Gesicht. Falls person.profileFace geändert wurde,
           greift dieser neue Wert hier sofort beim nächsten Render-Zyklus. #}
        {% set displayFace = person.profileFace ?: person.videoFaces|first %}

        <a href="{{ path('person_detail', { id: person.id }) }}"
           class="d-inline-block shadow-sm border border-2 border-white rounded-circle overflow-hidden bg-light hover-zoom"
           style="width: 120px; height: 120px; position: relative; transition: transform 0.2s ease-in-out;">

            {% if displayFace %}
                {# Cache-Busting: Die ?v= ID sorgt dafür, dass die Liste das Bild aktualisiert,
                   sobald du in der Detailansicht ein neues Face gewählt hast. #}
                {% set imagePath = imgproxy_url(displayFace.faceImagePath) ~ '?v=' ~ displayFace.id %}
                <div style="{{ face_zoom_style(imagePath, displayFace.boundingBox, 0.1) }}"></div>
            {% else %}
                <div class="d-flex align-items-center justify-content-center h-100 fw-bold text-muted bg-soft-secondary">
                    {{ person.name|slice(0, 2)|upper }}
                </div>
            {% endif %}
        </a>

        <h5 class="mt-3 mb-1 fw-bold">
            <a href="{{ path('person_detail', { id: person.id }) }}" class="text-decoration-none text-dark">
                {{ person.name }}
            </a>
        </h5>

        {% if person.fullName %}
            <div class="small fw-bold text-muted mb-1">{{ person.fullName }}</div>
        {% endif %}

        <div class="small text-muted mb-3">
            {% if person.status.value == 'merged' %}
                <span class="badge bg-soft-secondary text-secondary px-2">
                    MERGED
                </span>
                {% if person.mergedInto %}
                    <div class="mt-1 small">
                        → <a href="{{ path('person_detail', { id: person.mergedInto.id }) }}" class="text-decoration-none">{{ person.mergedInto.name }}</a>
                    </div>
                {% endif %}
            {% else %}
                <span class="badge {{ person.status.value == 'identified' ? 'bg-soft-success text-success' : 'bg-soft-warning text-warning' }} px-2">
                    {{ person.status.value|upper }}
                </span>
            {% endif %}
        </div>
    </div>

    <div class="card-body pt-0">
        {# Metadaten-Badges #}
        <div class="d-flex flex-wrap justify-content-center gap-1 mb-3">
            <span class="badge rounded-pill bg-light text-dark border fw-normal" title="Sichtungen">
                <i class="fas fa-video me-1 text-primary"></i> {{ person.videoFaces|length }}
            </span>
            <span class="badge rounded-pill bg-light text-dark border fw-normal" title="Geschlecht">
                <i class="fas fa-venus-mars me-1 text-info"></i> {{ (person.gender ?: person.probablyGender)|slice(0,1)|upper }}
            </span>
            {% if person.age %}
                <span class="badge rounded-pill bg-light text-dark border fw-normal" title="Alter">
                    <i class="fas fa-birthday-cake me-1 text-danger"></i> {{ person.age }}
                </span>
            {% endif %}
            {% if person.relation %}
                <span class="badge rounded-pill bg-light text-dark border fw-normal" title="Beziehung">
                    <i class="fas fa-user-tag me-1 text-success"></i> {{ person.relation|slice(0,10) }}{{ person.relation|length > 10 ? '..' : '' }}
                </span>
            {% endif %}
        </div>

        <div class="text-center">
            <a href="{{ path('person_detail', { id: person.id }) }}" class="btn btn-sm btn-outline-primary w-100 py-1" style="font-size: 0.75rem;">
                Details & Merge
            </a>
        </div>
    </div>
</div>