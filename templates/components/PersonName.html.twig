<div{{ attributes }}>
    <div class="border p-3 mt-4 bg-light shadow-sm">
        {{ form_start(form, {
            attr: {
                'data-action': 'live#action:prevent',
                'data-live-action-param': 'submit',
                'class': 'row gy-3'
            }
        }) }}

        {{ form_row(form.name) }}
        {{ form_row(form._token) }}
        <button type="submit" class="btn btn-secondary col-5 ms-3">
            <i class="fas fa-pen me-2"></i> Rename
        </button>
        {{ form_end(form) }}
    </div>
</div>