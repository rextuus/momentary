<div {{ attributes }}>
    <div class="container mt-4">
        {# Flash-Messages für Erfolgsmeldungen #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show shadow-sm mb-4">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <nav aria-label="breadcrumb">
            <ol class="breadcrumb small">
                <li class="breadcrumb-item"><a href="{{ path('person_index') }}">Personen</a></li>
                <li class="breadcrumb-item active text-muted">{{ person.name }}</li>
            </ol>
        </nav>

        <div class="row">
            <div class="col-md-3">
                <div class="card shadow-sm border-0 mb-4 overflow-hidden">
                    {# HEADER: Profilbild mit Zoom-Fokus #}
                    <div class="bg-dark border-bottom" style="height: 220px; position: relative; overflow: hidden;">
                        {% set displayFace = person.profileFace ?: person.videoFaces|first %}

                        {% if displayFace %}
                            <div style="{{ face_zoom_style(asset('uploads/faces/' ~ displayFace.faceImagePath), displayFace.boundingBox, 0.1) }}"></div>
                        {% else %}
                            <div class="d-flex align-items-center justify-content-center h-100 bg-secondary text-white">
                                <i class="fas fa-user fa-3x"></i>
                            </div>
                        {% endif %}
                    </div>

                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted mb-1">Rufname / Kurzname</label>
                            <input type="text" data-model="person.name" class="form-control form-control-sm shadow-none" placeholder="z.B. Oma">
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted mb-1">Voller Name</label>
                            <input type="text" data-model="person.fullName" class="form-control form-control-sm shadow-none" placeholder="Vor- und Nachname">
                        </div>

                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted mb-1">Alter</label>
                                <input type="number" data-model="person.age" class="form-control form-control-sm shadow-none" placeholder="Alter">
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted mb-1">Geschlecht</label>
                                <select data-model="person.gender" class="form-select form-select-sm shadow-none">
                                    <option value="">Unbekannt</option>
                                    <option value="male">Männlich</option>
                                    <option value="female">Weiblich</option>
                                    <option value="other">Anderes</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted mb-1">Beziehung / Rolle</label>
                            <input type="text" data-model="person.relation" class="form-control form-control-sm shadow-none" placeholder="z.B. Bräutigam, Gast...">
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted mb-1">Merkmale</label>
                            <textarea data-model="person.characteristics" class="form-control form-control-sm shadow-none" rows="2" placeholder="Brille, Bart, rotes Kleid..."></textarea>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted mb-1">Notizen</label>
                            <textarea data-model="person.description" class="form-control form-control-sm shadow-none" rows="3" placeholder="Zusätzliche Infos..."></textarea>
                        </div>

                        <button data-action="live#action" data-live-action-param="save" class="btn btn-success btn-sm w-100 mb-3 shadow-sm">
                            <i class="fas fa-save me-1"></i> Speichern
                        </button>

                        <div class="d-flex justify-content-center gap-2 mb-4">
                            <span class="badge {{ person.status.value == 'identified' ? 'bg-success' : 'bg-warning text-dark' }} px-2 py-1">
                                {{ person.status.value|upper }}
                            </span>
                            <span class="badge bg-light text-dark border px-2 py-1">
                                <i class="fas fa-venus-mars me-1 text-primary"></i> {{ person.gender ?: person.getProbablyGender|capitalize }}
                            </span>
                        </div>

                        {# NEU: Merge-Bereich #}
                        <div class="p-3 border rounded bg-light text-start mt-4">
                            <label class="form-label small fw-bold text-muted mb-2">Mit anderer Person zusammenführen</label>
                            {{ form_start(form, {
                                attr: {
                                    'data-action': 'live#action:prevent',
                                    'data-live-action-param': 'merge',
                                }
                            }) }}
                            <div class="input-group input-group-sm">
                                {{ form_widget(form.target, { attr: { 'class': 'form-select border-0 bg-transparent shadow-none' } }) }}
                                <button type="submit" class="btn btn-primary" title="Merge" onclick="return confirm('Diese Person wirklich mit der Zielperson verschmelzen? Dies kann nicht rückgängig gemacht werden.')">
                                    <i class="fas fa-compress-alt"></i>
                                </button>
                            </div>
                            {{ form_end(form, {render_rest: false}) }}
                            <div class="form-text mt-1" style="font-size: 0.7rem;">
                                Alle Sichtungen werden übertragen und diese Person gelöscht.
                            </div>
                        </div>
                    </div>
                </div>

                {# Referenz-Bilder (DetectionFaces) #}
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white fw-bold small text-uppercase text-muted">Referenz-Bilder</div>
                    <div class="card-body p-2">
                        <div class="d-flex flex-wrap gap-1">
                            {% for detectionFace in person.detectionFaces %}
                                <img src="{{ display_image(detectionFace) }}"
                                     class="rounded border shadow-sm img-fluid"
                                     style="width: 100%; height: auto; object-fit: cover; cursor: pointer;"
                                     data-bs-toggle="modal"
                                     data-bs-target="#imageModal"
                                     data-bs-img="{{ display_image(detectionFace) }}">
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-9">
                <div class="d-flex justify-content-between align-items-end mb-3">
                    <h3 class="h4 mb-0">Sichtungen</h3>
                    <span class="badge bg-secondary rounded-pill">{{ person.videoFaces|length }}</span>
                </div>

                <div class="row g-2">
                    {% for face in person.videoFaces %}
                        <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                            <div class="card h-100 border-0 shadow-sm overflow-hidden position-relative appearance-card bg-black" style="aspect-ratio: 16/9;">
                                <img src="{{ asset('uploads/faces/' ~ face.faceImagePath) }}"
                                     class="w-100 h-100"
                                     style="object-fit: cover; cursor: pointer;"
                                     data-bs-toggle="modal"
                                     data-bs-target="#imageModal"
                                     data-bs-img="{{ asset('uploads/faces/' ~ face.faceImagePath) }}"
                                     data-bs-box="{{ face.boundingBoxStyles }}"
                                     data-bs-caption="Sichtung in {{ face.video.title }} ({{ face.timestamp }}s)">

                                {# Aktions-Buttons oben rechts #}
                                <div class="position-absolute top-0 end-0 m-1 d-flex flex-column gap-1" style="z-index: 10;">

                                    {# Als Profilbild setzen (Blau) #}
                                    <button class="btn btn-primary btn-sm shadow-sm"
                                            title="Als Profilbild setzen"
                                            data-action="live#action"
                                            data-live-action-param="setAsProfile"
                                            data-live-face-id-param="{{ face.id }}"
                                            style="width: 26px; height: 26px; padding: 0; display: flex; align-items: center; justify-content: center;">
                                        <i class="fas fa-camera text-white" style="font-size: 0.7rem;"></i>
                                    </button>

                                    {# Neu zuordnen (Gelb ohne Confirm) #}
                                    <button class="btn btn-warning btn-sm shadow-sm"
                                            title="Falsche Zuordnung: Von dieser Person entfernen"
                                            type="button"
                                            data-action="live#action"
                                            data-live-action-param="reassignFace"
                                            data-live-face-id-param="{{ face.id }}"
                                            style="width: 26px; height: 26px; padding: 0; display: flex; align-items: center; justify-content: center;">
                                        <i class="fas fa-scissors text-dark" style="font-size: 0.7rem;"></i>
                                    </button>
                                </div>


                                {# Zeitstempel-Badge unten links #}
                                <div class="position-absolute bottom-0 start-0 m-1 px-1 bg-black bg-opacity-50 text-white rounded small" style="font-size: 0.65rem; z-index: 2;">
                                    {{ face.timestamp }}s
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    {# Das Modal wurde in base.html.twig zentralisiert #}
</div>