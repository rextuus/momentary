<div {{ attributes }}>
    <div class="container mt-4">
        {# Flash-Messages für Erfolgsmeldungen #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show shadow-sm mb-4">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <nav aria-label="breadcrumb">
            <ol class="breadcrumb small">
                <li class="breadcrumb-item"><a href="{{ path('person_index') }}">Personen</a></li>
                <li class="breadcrumb-item active text-muted">{{ person.name }}</li>
            </ol>
        </nav>

        <div class="row">
            <div class="col-md-3">
                <div class="card shadow-sm border-0 mb-4 overflow-hidden">
                    {# HEADER: Profilbild mit Zoom-Fokus #}
                    <div class="bg-dark border-bottom" style="height: 220px; position: relative; overflow: hidden;">
                        {% set displayFace = person.profileFace ?: person.videoFaces|first %}

                        {% if displayFace %}
                            <div style="{{ face_zoom_style(asset('uploads/faces/' ~ displayFace.faceImagePath), displayFace.boundingBox, 0.1) }}"></div>
                        {% else %}
                            <div class="d-flex align-items-center justify-content-center h-100 bg-secondary text-white">
                                <i class="fas fa-user fa-3x"></i>
                            </div>
                        {% endif %}
                    </div>

                    <div class="card-body text-center">
                        <h4 class="fw-bold mb-1">{{ person.name }}</h4>
                        <div class="d-flex justify-content-center gap-2 mt-2">
                            <span class="badge {{ person.status.value == 'identified' ? 'bg-success' : 'bg-warning text-dark' }} px-2 py-1">
                                {{ person.status.value|upper }}
                            </span>
                            <span class="badge bg-light text-dark border px-2 py-1">
                                <i class="fas fa-venus-mars me-1 text-primary"></i> {{ person.getProbablyGender|capitalize }}
                            </span>
                        </div>
                    </div>
                </div>

                {# Referenz-Bilder (DetectionFaces) #}
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white fw-bold small text-uppercase text-muted">Referenz-Bilder</div>
                    <div class="card-body p-2">
                        <div class="d-flex flex-wrap gap-1">
                            {% for detectionFace in person.detectionFaces %}
                                <img src="{{ display_image(detectionFace) }}"
                                     class="rounded border shadow-sm img-fluid"
                                     style="width: 100%; height: auto; object-fit: cover; cursor: pointer;"
                                     data-bs-toggle="modal"
                                     data-bs-target="#imageModal"
                                     data-bs-img="{{ display_image(detectionFace) }}">
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-9">
                <div class="d-flex justify-content-between align-items-end mb-3">
                    <h3 class="h4 mb-0">Sichtungen</h3>
                    <span class="badge bg-secondary rounded-pill">{{ person.videoFaces|length }}</span>
                </div>

                <div class="row g-2">
                    {% for face in person.videoFaces %}
                        <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                            <div class="card h-100 border-0 shadow-sm overflow-hidden position-relative appearance-card bg-black" style="aspect-ratio: 16/9;">
                                <img src="{{ asset('uploads/faces/' ~ face.faceImagePath) }}"
                                     class="w-100 h-100"
                                     style="object-fit: cover; cursor: pointer;"
                                     data-bs-toggle="modal"
                                     data-bs-target="#imageModal"
                                     data-bs-img="{{ asset('uploads/faces/' ~ face.faceImagePath) }}"
                                     data-bs-box="{{ face.boundingBoxStyles }}"
                                     data-bs-caption="Sichtung in {{ face.video.title }} ({{ face.timestamp }}s)">

                                {# Aktions-Buttons oben rechts #}
                                <div class="position-absolute top-0 end-0 m-1 d-flex flex-column gap-1" style="z-index: 10;">

                                    {# Als Profilbild setzen (Blau) #}
                                    <button class="btn btn-primary btn-sm shadow-sm"
                                            title="Als Profilbild setzen"
                                            data-action="live#action"
                                            data-live-action-param="setAsProfile"
                                            data-live-face-id-param="{{ face.id }}"
                                            style="width: 26px; height: 26px; padding: 0; display: flex; align-items: center; justify-content: center;">
                                        <i class="fas fa-camera text-white" style="font-size: 0.7rem;"></i>
                                    </button>

                                    {# In neue Person verschieben (Gelb mit Confirm) #}
                                    <button class="btn btn-warning btn-sm shadow-sm"
                                            title="Falsche Zuordnung: In neue Person auslagern"
                                            type="button"
                                            onclick="if (!confirm('Dieses Gesicht wirklich von {{ person.name }} trennen und eine neue unbekannte Person dafür anlegen?')) return;"
                                            data-action="live#action"
                                            data-live-action-param="splitToNewPerson"
                                            data-live-face-id-param="{{ face.id }}"
                                            style="width: 26px; height: 26px; padding: 0; display: flex; align-items: center; justify-content: center;">
                                        <i class="fas fa-user-plus text-dark" style="font-size: 0.7rem;"></i>
                                    </button>
                                </div>

                                {# Zeitstempel-Badge unten links #}
                                <div class="position-absolute bottom-0 start-0 m-1 px-1 bg-black bg-opacity-50 text-white rounded small" style="font-size: 0.65rem; z-index: 2;">
                                    {{ face.timestamp }}s
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    {# Detail-Modal für Bilder #}
    <div class="modal fade" id="imageModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content bg-dark border-0 shadow-lg">
                <div class="modal-header border-0 pb-0">
                    <h6 class="modal-title text-white opacity-75" id="modalCaption">Vorschau</h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center p-0 pb-4">
                    <div class="position-relative d-inline-block mt-2">
                        <img src="" id="modalImage" class="img-fluid rounded" alt="Full view">
                        <div id="modalBox" class="position-absolute border border-primary border-4 shadow" style="display: none; pointer-events: none;"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>