<div {{ attributes }}>
    {# Flash-Messages für Fehlermeldungen #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-danger alert-dismissible fade show shadow-sm mx-auto mb-3" style="max-width: 90%;">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {% set person = this.unidentifiedPerson %}

    {% if person %}
        {# Wir holen uns das spezifisch ausgewählte Gesicht über die PHP-Getter-Logik #}
        {% set mainFace = this.activeFace %}

        <div class="row justify-content-center">
            <div class="col-md-11">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h4 mb-0 text-secondary">Identität klären
                        <span class="badge rounded-pill bg-primary ms-2" style="font-size: 0.5em;">
                            {{ this.remainingCount }} verbleibend
                        </span>
                    </h2>
                    <button type="button" class="btn btn-sm btn-outline-secondary shadow-sm" data-action="live#action" data-live-action-param="skip">
                        Überspringen
                    </button>
                </div>

                <div class="card shadow border-0 overflow-hidden">
                    <div class="card-body p-0">
                        <div class="row g-0">

                            {# LINKE SEITE: Visualisierung & Galerie #}
                            <div class="col-lg-7 bg-dark p-4 d-flex flex-column align-items-center" style="min-height: 750px;">

                                {# 1. OBEN: ZOOM #}
                                <div class="text-center w-100 mb-4">
                                    <small class="text-light opacity-50 d-block mb-2 text-uppercase fw-bold">Gesichts-Zoom</small>
                                    <div class="d-inline-block shadow-lg border border-4 border-white rounded overflow-hidden bg-black"
                                         style="width: 300px; height: 300px;">

                                        {% if mainFace and mainFace.boundingBox %}
                                            {% set box = mainFace.boundingBox %}

                                            {# Wir berechnen, wie breit das Bild sein muss, damit die Box 300px füllt #}
                                            {# Wenn die Box 10% breit ist (0.1), muss das Bild 10x so groß wie der Container sein #}
                                            {% set zoomFactor = 0.35 %} {# Wert anpassen: Kleiner = mehr Zoom, Größer = weniger Zoom #}
                                            {% set imgWidth = (1 / (box.Width ?: 0.1)) * 100 * zoomFactor %}

                                            {# Die Mitte der Box in Prozent #}
                                            {% set centerX = (box.Left + (box.Width / 2)) * 100 %}
                                            {% set centerY = (box.Top + (box.Height / 2)) * 100 %}

                                            <img src="{{ asset('uploads/faces/' ~ mainFace.faceImagePath) }}"
                                                 style="width: {{ imgWidth }}%;
                                                         height: auto;
                                                         aspect-ratio: 16/9; {# Oder das Format deiner Quelldaten #}
                                                         object-fit: none;
                                                         object-position: {{ centerX }}% {{ centerY }}%;
                                                         display: block;
                                                         width: 300px;
                                                         height: 300px;">
                                        {% else %}
                                            <div class="text-white p-5">Vorschau nicht verfügbar</div>
                                        {% endif %}
                                    </div>
                                </div>

                                {# 2. MITTE: KONTEXT (MIT BOX) #}
                                <div class="text-center w-100 mb-4">
                                    <small class="text-light opacity-50 d-block mb-2 text-uppercase fw-bold">Kontext im Video</small>
                                    <div class="position-relative d-inline-block shadow border border-1 border-secondary rounded overflow-hidden bg-black" style="max-width: 450px;">
                                        {% if mainFace %}
                                            <img src="{{ asset('uploads/faces/' ~ mainFace.faceImagePath) }}"
                                                 class="img-fluid"
                                                 style="width: 100%; opacity: 0.4; display: block;"
                                                 alt="Context">

                                            {% if mainFace.boundingBoxStyles %}
                                                <div style="position: absolute; border: 2px solid #ff0000;
                                                            box-shadow: 0 0 12px rgba(255,0,0,0.9); pointer-events: none;
                                                            {{ mainFace.boundingBoxStyles|raw }}"></div>
                                            {% endif %}
                                        {% endif %}
                                    </div>
                                </div>

                                {# 3. UNTEN: GALERIE (Klickbare Thumbnails) #}
                                <div class="w-100 mt-auto pt-3 border-top border-secondary">
                                    <small class="text-light opacity-50 d-block mb-2 text-uppercase fw-bold text-center">Aufnahmen dieser Person</small>
                                    <div class="d-flex flex-wrap justify-content-center gap-2 overflow-auto py-2" style="max-height: 160px;">
                                        {% for face in person.videoFaces %}
                                            <div class="position-relative"
                                                 style="cursor: pointer;"
                                                 data-action="click->live#action"
                                                 data-live-action-param="selectFace"
                                                 data-live-face-id-param="{{ face.id }}">

                                                <img src="{{ asset('uploads/faces/' ~ face.faceImagePath) }}"
                                                     class="rounded border {{ (mainFace and face.id == mainFace.id) ? 'border-primary border-4 shadow' : 'border-secondary opacity-50' }}"
                                                     style="width: 70px; height: 70px; object-fit: cover; transition: all 0.2s;"
                                                     alt="Thumbnail">

                                                {% if mainFace and face.id == mainFace.id %}
                                                    <span class="position-absolute top-0 start-50 translate-middle badge rounded-pill bg-primary" style="font-size: 0.6em; z-index: 10;">AKTIV</span>
                                                {% endif %}
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>

                            {# RECHTE SEITE: Formular #}
                            <div class="col-lg-5 p-4 bg-white d-flex flex-column border-start">
                                {{ form_start(form) }}
                                <h5 class="fw-bold mb-4">Zuweisung</h5>

                                <div class="mb-4">
                                    <label class="form-label fw-bold text-primary small">Bestehende Person finden</label>
                                    {{ form_widget(form.targetPerson) }}
                                </div>

                                <div class="text-center position-relative mb-4">
                                    <hr><span class="position-absolute top-50 start-50 translate-middle bg-white px-2 text-muted small">ODER</span>
                                </div>

                                <div class="mb-5">
                                    <label class="form-label fw-bold text-success small">Neue Identität erstellen</label>
                                    <input type="text"
                                           data-model="newName"
                                           class="form-control form-control-lg border-success shadow-sm"
                                           placeholder="Name eingeben..."
                                           autocomplete="off">
                                </div>

                                <div class="mt-auto">
                                    <button type="button"
                                            class="btn btn-primary w-100 btn-lg py-3 shadow fw-bold"
                                            data-action="live#action"
                                            data-live-action-param="prevent|processIdentification">
                                        Speichern & Nächste
                                    </button>
                                </div>
                                {# Verhindert doppeltes Rendern von Feldern #}
                                {{ form_rest(form) }}
                                {{ form_end(form, {'render_rest': false}) }}
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% else %}
        <div class="text-center py-5">
            <div class="display-1 text-muted mb-4"><i class="bi bi-check2-circle"></i></div>
            <h3 class="text-muted fw-light">Alles erledigt!</h3>
            <p class="text-secondary">Alle Personen wurden erfolgreich identifiziert.</p>
            <a href="/" class="btn btn-primary mt-3 px-5 shadow-sm">Zum Dashboard</a>
        </div>
    {% endif %}
</div>