<div {{ attributes }}>
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-danger alert-dismissible fade show">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {% set person = this.unidentifiedPerson %}

    {% if person %}
        <div class="row justify-content-center">
            <div class="col-md-11">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2>Identitäten klären <span class="badge bg-primary ms-2">{{ this.remainingCount }} übrig</span></h2>

                    {# ABSOLUT SICHERE VARIANTE FÜR SKIP #}
                    <button type="button"
                            class="btn btn-outline-secondary btn-sm"
                            data-action="live#action"
                            data-live-action-param="skip">
                        Überspringen
                    </button>
                </div>

                {{ form_start(form) }}
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <div class="d-flex flex-wrap gap-2 mb-4">
                            {% for face in person.videoFaces %}
                                <img src="{{ asset('uploads/faces/' ~ face.faceImagePath) }}"
                                     class="rounded img-thumbnail"
                                     style="width: 120px; height: 120px; object-fit: cover;">
                            {% endfor %}
                        </div>

                        <div class="row g-3 p-3 bg-light rounded border">
                            {# ID am Wrapper für TomSelect Re-Init #}
                            <div class="col-md-6 border-end" id="wrapper-search-{{ person.id }}">
                                <label class="form-label fw-bold text-primary">1. Bestehende Person finden</label>
                                {{ form_widget(form.targetPerson) }}
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold text-success">2. Oder neu anlegen</label>
                                <input type="text"
                                       data-model="newName"
                                       class="form-control"
                                       placeholder="Name eingeben..."
                                       autocomplete="off">
                            </div>

                            <div class="col-12 text-center mt-4">
                                <button type="button"
                                        class="btn btn-primary btn-lg px-5"
                                        data-action="live#action"
                                        data-live-action-param="prevent|processIdentification">
                                    Bestätigen & Weiter
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                {{ form_rest(form) }}
                {{ form_end(form, {'render_rest': false}) }}
            </div>
        </div>
    {% else %}
        <div class="text-center py-5">
            <h3 class="text-muted">Keine unidentifizierten Personen mehr gefunden.</h3>
            <a href="/" class="btn btn-primary mt-3">Zum Dashboard</a>
        </div>
    {% endif %}
</div>