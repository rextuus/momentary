{% extends 'base.html.twig' %}

{% block title %}Tag-Verwaltung - Momentary{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">
                <i class="fas fa-tags text-primary me-2"></i>
                Tag- & Kategorien-Verwaltung
            </h1>
            
            <p class="text-muted mb-4">
                Hier können Sie Kategorien erstellen und bearbeiten, um Szenen in Ihren Videos zu klassifizieren. 
                Jeder Kategorie können beliebig viele Tags zugeordnet werden.
            </p>

            {{ component('TagManagerComponent') }}
        </div>
    </div>
</div>
{% endblock %}
