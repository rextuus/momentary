{% extends 'base.html.twig' %}

{% block title %}Resolve Identities - Momentary{% endblock %}

{% block body %}
    <div class="container pb-5">
        <div class="mb-4">
            <h1 class="fw-bold mb-0">Identity Resolver</h1>
            <p class="text-muted">Ordne erkannte Gesichter bekannten Personen zu oder erstelle neue Profile.</p>
        </div>

        <div class="card p-4 shadow-sm border-0 bg-white">
            {# Die Live-Komponente #}
            {{ component('PersonResolverComponent', { 
                currentPersonId: currentPersonId,
                fromQuickResolve: fromQuickResolve,
                fromTinder: fromTinder,
                mergeIds: mergeIds
            }) }}
        </div>
    </div>
{% endblock %}