{% extends 'base.html.twig' %}

{% block title %}Video Upload - Momentary{% endblock %}

{% block body %}
<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card p-4 shadow-sm border-0">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-3 me-3">
                        <i class="fas fa-cloud-upload-alt fa-2x text-primary"></i>
                    </div>
                    <div>
                        <h2 class="fw-bold mb-0">Video Upload</h2>
                        <p class="text-muted mb-0 small text-uppercase fw-bold">In das Import-Verzeichnis hochladen</p>
                    </div>
                </div>

                <div class="alert alert-info border-0 shadow-sm d-flex align-items-center">
                    <i class="fas fa-info-circle fa-lg me-3"></i>
                    <div>
                        Dateien werden nach <code>{{ importDir }}</code> hochgeladen und stehen danach im Video-Formular zur Auswahl.
                    </div>
                </div>

                <form method="post" enctype="multipart/form-data">
                    <div class="mb-4">
                        <label for="video_file" class="form-label fw-bold small text-uppercase text-muted">Video-Datei wählen</label>
                        <input type="file" name="video_file" id="video_file" class="form-control form-control-lg" required>
                        <div class="form-text mt-2">Unterstützte Formate: MPG, MP4, MOV, AVI etc.</div>
                    </div>

                    <div class="form-check mb-4">
                        <input class="form-check-input" type="checkbox" name="redirect_to_new" id="redirect_to_new" checked>
                        <label class="form-check-label" for="redirect_to_new">
                            Nach dem Upload direkt zum Video-Formular springen
                        </label>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                            <i class="fas fa-upload me-2"></i>Hochladen
                        </button>
                        <a href="{{ path('video_new') }}" class="btn btn-link text-muted">Zurück zum Formular</a>
                    </div>
                </form>
            </div>

            <div class="mt-4 card p-4 border-0 shadow-sm bg-light">
                <h5 class="fw-bold"><i class="fas fa-history me-2 text-muted"></i>Hinweis</h5>
                <p class="small text-muted mb-0">
                    Große Dateien können je nach Serverkonfiguration etwas Zeit in Anspruch nehmen. 
                    Der Browser zeigt den Fortschritt in der Statusleiste an.
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
