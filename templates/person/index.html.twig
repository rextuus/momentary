{% extends 'base.html.twig' %}
{% block title %}Personen - Momentary{% endblock %}

{% block body %}
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="fw-bold mb-0">Personen</h1>
                <p class="text-muted">Alle identifizierten Personen in deinem Archiv</p>
            </div>
        </div>

        <div class="row g-4">
            {% for person in persons %}
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <div class="hover-card h-100">
                        {{ component('PersonComponent', {
                            person: person,
                            key: 'person-' ~ person.id
                        }) }}
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center py-5">
                    <div class="text-muted mb-3">
                        <i class="fas fa-users-slash fa-3x"></i>
                    </div>
                    <p class="text-muted">Noch keine Personen in der Datenbank gefunden.</p>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}