{% extends 'base.html.twig' %}

{% block title %}Video Pipeline Dashboard{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h1 class="display-5 fw-bold text-primary">Momentary</h1>
                <p class="text-muted">Video Processing Pipeline Control Center</p>
            </div>
            <a href="{{ path('video_new') }}" class="btn btn-primary shadow-sm">
                <i class="fas fa-plus me-2"></i>Neues Video
            </a>
        </div>

        <div class="row g-4">
            {% for video in videos %}
                <div class="col-12">
                    <div class="card border-0 shadow-sm overflow-hidden">
                        <div class="row g-0">
                            <!-- Status-Indikator an der Seite -->
                            {% set statusInfo = {
                                'pending': {'color': 'secondary', 'icon': 'clock'},
                                'downloading': {'color': 'info', 'icon': 'download'},
                                'scene_detection': {'color': 'warning', 'icon': 'cut'},
                                'splitting': {'color': 'primary', 'icon': 'film'},
                                'analyzing_faces': {'color': 'dark', 'icon': 'user-search'},
                                'completed': {'color': 'success', 'icon': 'check-circle'},
                                'error': {'color': 'danger', 'icon': 'exclamation-triangle'}
                            }[video.status.value] ?? {'color': 'secondary', 'icon': 'question'} %}

                            <div class="col-md-auto bg-{{ statusInfo.color }} d-flex align-items-center justify-content-center" style="width: 60px; min-height: 100px;">
                                <i class="fas fa-{{ statusInfo.icon }} text-white fa-lg"></i>
                            </div>

                            <div class="col">
                                <div class="card-body d-flex flex-column flex-md-row align-items-md-center justify-content-between">
                                    <div class="mb-3 mb-md-0">
                                        <div class="d-flex align-items-center mb-1">
                                            <h5 class="card-title mb-0 me-3">{{ video.title }}</h5>
                                            <span class="badge rounded-pill bg-{{ statusInfo.color }} bg-opacity-10 text-{{ statusInfo.color }} border border-{{ statusInfo.color }}">
                                            {{ video.status.value|upper }}
                                        </span>
                                        </div>
                                        <p class="card-text small text-muted mb-2">
                                            <i class="fab fa-youtube me-1"></i> {{ video.youtubeUrl }}
                                        </p>
                                        {% if video.localPath %}
                                            <div class="d-flex align-items-center text-truncate" style="max-width: 400px;">
                                                <i class="fas fa-folder-open small me-2 text-muted"></i>
                                                <code class="small text-pink" style="font-size: 0.75rem;">{{ video.localPath }}</code>
                                            </div>
                                        {% endif %}
                                    </div>

                                    <div class="d-flex flex-wrap gap-2 align-items-center">
                                        <!-- Timeline Link -->
                                        <a href="{{ path('video_timeline', {id: video.id}) }}" class="btn btn-sm btn-light border">
                                            <i class="fas fa-chart-line me-1 text-primary"></i> Timeline
                                        </a>

                                        <div class="vr mx-2 d-none d-md-block"></div>

                                        <!-- Action Buttons -->
                                        <div class="btn-group shadow-sm">
                                            <a href="{{ path('app_video_trigger', {id: video.id, step: 'download'}) }}"
                                               class="btn btn-sm btn-outline-primary" title="Download neu starten">
                                                <i class="fas fa-sync-alt"></i> DL
                                            </a>
                                            <a href="{{ path('app_video_trigger', {id: video.id, step: 'scenes'}) }}"
                                               class="btn btn-sm btn-outline-warning {{ not video.localPath ? 'disabled' }}" title="Szenenerkennung">
                                                <i class="fas fa-cut"></i> SC
                                            </a>
                                            <a href="{{ path('app_video_trigger', {id: video.id, step: 'split'}) }}"
                                               class="btn btn-sm btn-outline-success {{ not video.localPath ? 'disabled' }}" title="Analyse">
                                                <i class="fas fa-microchip"></i> AN
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center py-5">
                    <div class="text-muted mb-3">
                        <i class="fas fa-video-slash fa-3x"></i>
                    </div>
                    <h3>Noch keine Videos in der Pipeline</h3>
                    <p>Füge dein erstes Video hinzu, um die Magie zu starten.</p>
                    <a href="{{ path('video_new') }}" class="btn btn-primary mt-2">Jetzt starten</a>
                </div>
            {% endfor %}
        </div>
    </div>

    <style>
        .text-pink { color: #d63384; }
        .card { transition: transform 0.2s ease, shadow 0.2s ease; }
        .card:hover { transform: translateY(-2px); box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important; }
        .btn-group .btn { border-width: 1px; }
    </style>
{% endblock %}