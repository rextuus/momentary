{% extends 'base.html.twig' %}

{% block title %}Videos - Momentary{% endblock %}

{% block body %}
    <div class="container pb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="fw-bold mb-0">Videos</h1>
                <p class="text-muted">Verwalte deine Video-Pipeline</p>
            </div>
            <a href="{{ path('video_new') }}" class="btn btn-primary shadow-sm rounded-pill px-4">
                <i class="fas fa-plus me-2"></i>Neues Video
            </a>
        </div>

        <div class="row g-4">
            {% for video in videos %}
                <div class="col-12">
                    <div class="card overflow-hidden">
                        <div class="row g-0">
                            {% set statusInfo = {
                                'pending': {'color': 'secondary', 'icon': 'clock'},
                                'downloading': {'color': 'info', 'icon': 'download'},
                                'scene_detection': {'color': 'warning', 'icon': 'cut'},
                                'splitting': {'color': 'primary', 'icon': 'film'},
                                'analyzing_faces': {'color': 'dark', 'icon': 'user-search'},
                                'completed': {'color': 'success', 'icon': 'check-circle'},
                                'error': {'color': 'danger', 'icon': 'exclamation-triangle'}
                            }[video.status.value] ?? {'color': 'secondary', 'icon': 'question'} %}

                            <div class="col-md-auto bg-{{ statusInfo.color }} d-flex align-items-center justify-content-center" style="width: 60px; min-height: 100px;">
                                <i class="fas fa-{{ statusInfo.icon }} text-white fa-lg"></i>
                            </div>

                            <div class="col">
                                <div class="card-body d-flex flex-column flex-md-row align-items-md-center justify-content-between">
                                    <div class="mb-3 mb-md-0">
                                        <div class="d-flex align-items-center mb-1">
                                            <h5 class="card-title mb-0 me-3 fw-bold">
                                                <a href="{{ path('app_video_show', {id: video.id}) }}" class="text-decoration-none text-dark hover-primary">
                                                    {{ video.title }}
                                                </a>
                                            </h5>
                                            <span class="badge rounded-pill bg-{{ statusInfo.color }} bg-opacity-10 text-{{ statusInfo.color }} border border-{{ statusInfo.color }}">
                                                {{ video.status.value|upper }}
                                            </span>
                                        </div>
                                        <p class="card-text small text-muted mb-2">
                                            {% if video.youtubeUrl %}
                                                <i class="fab fa-youtube me-1 text-danger"></i> {{ video.youtubeUrl }}
                                            {% else %}
                                                <span class="text-warning"><i class="fas fa-exclamation-circle me-1"></i> YouTube-Link fehlt</span>
                                            {% endif %}
                                        </p>
                                        {% if video.localPath %}
                                            <div class="d-flex align-items-center text-truncate mb-2" style="max-width: 400px;">
                                                <i class="fas fa-file-video small me-2 text-muted"></i>
                                                <code class="small text-muted" style="font-size: 0.75rem;">{{ video.localPath|split('/')|last }}</code>
                                            </div>
                                        {% endif %}

                                        {% if video.status.value != 'completed' and video.status.value != 'pending' and video.status.value != 'error' %}
                                            <div class="mt-3" style="max-width: 400px;">
                                                {{ component('VideoProgressBar', { video: video }) }}
                                            </div>
                                        {% endif %}

                                        {% if video.status.value == 'error' and video.errorMessage %}
                                            <div class="alert alert-danger py-2 px-3 small mb-2 border-0 shadow-sm" style="font-size: 0.8rem;">
                                                <div class="fw-bold mb-1"><i class="fas fa-exclamation-circle me-1"></i> Fehler-Details:</div>
                                                <div class="font-monospace text-break">{{ video.errorMessage }}</div>
                                            </div>
                                        {% endif %}

                                        {% if not video.youtubeUrl %}
                                            <div class="mt-3 p-3 bg-light rounded-3 border">
                                                <div class="d-flex align-items-center mb-2">
                                                    <i class="fab fa-youtube text-danger me-2"></i>
                                                    <span class="small fw-bold text-dark">YouTube-Upload erforderlich</span>
                                                </div>
                                                <div class="d-flex flex-column flex-sm-row gap-2">
                                                    <a href="https://studio.youtube.com/" target="_blank" class="btn btn-sm btn-outline-danger">
                                                        YouTube Studio öffnen
                                                    </a>
                                                    <form action="{{ path('video_set_youtube_url', {id: video.id}) }}" method="POST" class="d-flex gap-2 flex-grow-1">
                                                        <input type="url" name="youtube_url" class="form-control form-control-sm" placeholder="URL hier einfügen" required>
                                                        <button type="submit" class="btn btn-sm btn-success">Speichern</button>
                                                    </form>
                                                </div>
                                            </div>
                                        {% endif %}
                                    </div>

                                    <div class="d-flex flex-wrap gap-2 align-items-center">
                                        <a href="{{ path('app_video_show', {id: video.id}) }}" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                                            <i class="fas fa-info-circle me-1"></i> Details
                                        </a>

                                        <a href="{{ path('video_timeline', {id: video.id}) }}" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                            <i class="fas fa-chart-line me-1"></i> Timeline
                                        </a>

                                        <div class="vr mx-2 d-none d-md-block"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center py-5">
                    <div class="text-muted mb-3">
                        <i class="fas fa-video-slash fa-3x"></i>
                    </div>
                    <h3>Noch keine Videos in der Pipeline</h3>
                    <p>Füge dein erstes Video hinzu, um die Magie zu starten.</p>
                    <a href="{{ path('video_new') }}" class="btn btn-primary mt-2">Jetzt starten</a>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}