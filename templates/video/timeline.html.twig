{% extends 'base.html.twig' %}

{% block title %}{{ video.title }} - Timeline{% endblock %}

{% block body %}
    <div class="container pb-5">
        <div class="d-flex justify-content-between align-items-start mb-4">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb small">
                        <li class="breadcrumb-item"><a href="{{ path('app_video_index') }}" class="text-decoration-none">Videos</a></li>
                        <li class="breadcrumb-item active">{{ video.title }}</li>
                    </ol>
                </nav>
                <h1 class="fw-bold mb-1">{{ video.title }}</h1>
                <p class="text-muted small">
                    <i class="fas fa-video me-2"></i>Video-Analyse Timeline
                    <span class="mx-2">|</span>
                    <i class="fas fa-film me-1"></i> {{ video.scenes|length }} Szenen
                </p>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-white border shadow-sm" onclick="expandAll()">
                    <i class="fas fa-expand-arrows-alt me-1"></i> Alle öffnen
                </button>
                <button class="btn btn-sm btn-white border shadow-sm" onclick="toggleUnknowns()">
                    <i class="fas fa-eye-slash me-1"></i> Filter Unbekannt
                </button>
            </div>
        </div>

        <div class="modern-timeline">
            {# Kapitel Manager #}
            {{ component('ChapterManagerComponent', { video: video }) }}

            {# Tag Manager #}
            {{ component('TagManagerComponent') }}

            {# Wir loopen nun primär über die Szenen #}
            {% for scene in video.scenes %}
                {{ component('SceneSectionComponent', {
                    scene: scene,
                    sceneNumber: loop.index
                }) }}
            {% else %}
                <div class="card p-5 text-center">
                    <i class="fas fa-ghost fa-3x text-muted mb-3"></i>
                    <p class="text-muted mb-0">Keine Szenen für dieses Video definiert.</p>
                </div>
            {% endfor %}
        </div>
    </div>

    {% include '_partials/_image_modal.html.twig' %}

    <style>
        .btn-white { background: #fff; }
        .btn-white:hover { background: #f8f9fa; }
        
        .modern-timeline {
            position: relative;
            padding-left: 1rem;
            border-left: 2px solid #e2e8f0;
            margin-left: 1.5rem;
        }

        .chapter-manager {
            margin-left: -1rem; /* Kompensiert das Padding der Timeline */
        }

        .scene-wrapper {
            transition: all 0.3s ease;
        }
    </style>

    <script>
        function toggleUnknowns() {
            document.querySelectorAll('.face-card-container').forEach(container => {
                if (container.querySelector('.is-unknown-card') || container.querySelector('.is-unknown')) {
                    container.closest('.col').classList.toggle('d-none');
                }
            });
        }

        function expandAll() {
            document.querySelectorAll('.collapse').forEach(el => {
                const bsCollapse = bootstrap.Collapse.getOrCreateInstance(el);
                bsCollapse.show();
            });
        }
    </script>
{% endblock %}