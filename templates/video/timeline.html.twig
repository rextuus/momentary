{% extends 'base.html.twig' %}

{% block title %}{{ video.title }} - Timeline{% endblock %}

{% block body %}
    <div class="container mt-5 pb-5">
        <div class="d-flex justify-content-between align-items-start mb-5">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb small">
                        <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}" class="text-decoration-none">Dashboard</a></li>
                        <li class="breadcrumb-item active">Timeline</li>
                    </ol>
                </nav>
                <h1 class="fw-bold mb-1">{{ video.title }}</h1>
                <p class="text-muted small">
                    <i class="fas fa-video me-2"></i>Video-Analyse Timeline
                    <span class="mx-2">|</span>
                    <i class="fas fa-film me-1"></i> {{ video.scenes|length }} Szenen
                </p>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-light border shadow-sm" onclick="expandAll()">
                    <i class="fas fa-expand-arrows-alt me-1"></i> Alle öffnen
                </button>
                <button class="btn btn-sm btn-light border shadow-sm" onclick="toggleUnknowns()">
                    <i class="fas fa-eye-slash me-1"></i> Filter Unbekannt
                </button>
            </div>
        </div>

        <div class="modern-timeline">
            {# Wir loopen nun primär über die Szenen #}
            {% for scene in video.scenes %}

                {# Filtere die Gesichter für diese Szene aus der Map oder direkt aus video.videoFaces #}
                {% set sceneFaces = []|merge(video.videoFaces|filter(f => f.timestamp >= scene.startSeconds and f.timestamp <= scene.endSeconds)) %}

                {{ component('SceneSectionComponent', {
                    scene: scene,
                    sceneNumber: loop.index
                }) }}

            {% else %}
                <div class="text-center py-5">
                    <i class="fas fa-ghost fa-3x text-muted mb-3"></i>
                    <p class="text-muted">Keine Szenen für dieses Video definiert.</p>
                </div>
            {% endfor %}
        </div>
    </div>

    {% include '_partials/_image_modal.html.twig' %}

    <style>
        /* Die Timeline-Linie verläuft jetzt hinter den Szenen-Komponenten */
        .modern-timeline {
            position: relative;
            padding-left: 1rem;
            border-left: 2px solid #e9ecef;
            margin-left: 1.5rem;
        }

        /* Verhindert, dass die Karten in der Szene zu groß werden */
        .scene-wrapper {
            transition: all 0.3s ease;
        }
    </style>

    <script>
        function toggleUnknowns() {
            // Sucht in den Komponenten nach Karten, die als "unknown" markiert sind
            document.querySelectorAll('.face-card-container').forEach(container => {
                if (container.querySelector('.is-unknown-card') || container.querySelector('.is-unknown')) {
                    container.closest('.col').classList.toggle('d-none');
                }
            });
        }

        function expandAll() {
            document.querySelectorAll('.collapse').forEach(el => {
                const bsCollapse = bootstrap.Collapse.getOrCreateInstance(el);
                bsCollapse.show();
            });
        }
    </script>
{% endblock %}