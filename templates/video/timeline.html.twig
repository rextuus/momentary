{% extends 'base.html.twig' %}

{% block title %}{{ video.title }} - Timeline{% endblock %}

{% block body %}
    <div class="container mt-5 pb-5">
        <div class="d-flex justify-content-between align-items-start mb-5">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb small">
                        <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}">Dashboard</a></li>
                        <li class="breadcrumb-item active">Timeline</li>
                    </ol>
                </nav>
                <h1 class="fw-bold mb-1">{{ video.title }}</h1>
                <p class="text-muted small">
                    <i class="fas fa-video me-2"></i>Video-Analyse Timeline | {{ video.videoFaces|length }} Detektionen
                </p>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-light border shadow-sm" onclick="toggleUnknowns()">
                    <i class="fas fa-eye-slash me-1"></i> Filter Unbekannt
                </button>
            </div>
        </div>

        <div class="modern-timeline">
            {% set lastTimestamp = null %}
            {% for key, facesAtTime in map.getTimeStamps %}
                {% if facesAtTime is not empty %}
                    {% set currentTimestamp = (facesAtTime|first).timestamp %}

                    {# Gap Logik #}
                    {% if lastTimestamp is not null and (currentTimestamp - lastTimestamp) > 30 %}
                        <div class="timeline-gap my-4 d-flex align-items-center justify-content-center">
                            <span class="badge rounded-pill bg-light text-muted border px-3 italic">
                                Pause: {{ (currentTimestamp - lastTimestamp)|round }}s
                            </span>
                        </div>
                    {% endif %}
                    {% set lastTimestamp = currentTimestamp %}

                    <div class="timeline-block mb-5 border-left ps-4 position-relative">
                        <div class="timeline-marker shadow-sm"></div>
                        <div class="mb-3"><span class="badge bg-dark fw-normal">{{ key | date('H:i:s') }}</span></div>

                        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-6 g-3">
                            {% for videoFace in facesAtTime %}
                                <div class="col face-item-wrapper">
                                    {{ component('FaceCardComponent', { videoFace: videoFace }) }}
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </div>
    </div>

    {% include '_partials/_image_modal.html.twig' %}

    <style>
        .modern-timeline { border-left: 2px solid #dee2e6; margin-left: 1rem; }
        .timeline-marker {
            position: absolute; left: -11px; top: 5px;
            width: 20px; height: 20px; background: #212529;
            border: 4px solid #fff; border-radius: 50%; z-index: 2;
        }
        .hover-scale:hover { transform: scale(1.1); }
    </style>

    <script>
        function toggleUnknowns() {
            document.querySelectorAll('.face-item-wrapper').forEach(wrapper => {
                if (wrapper.querySelector('.is-unknown-card')) { // Falls du die Klasse in der Komponente setzt
                    wrapper.classList.toggle('d-none');
                }
            });
        }
    </script>
{% endblock %}