{% extends 'base.html.twig' %}

{% block title %}Video Details: {{ video.title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://vjs.zencdn.net/8.10.0/video-js.css" rel="stylesheet" />
    <style>
        .video-js {
            font-family: 'Inter', sans-serif;
        }
        .vjs-big-play-centered .vjs-big-play-button {
            top: 50%;
            left: 50%;
            margin-top: -0.75em;
            margin-left: -1.5em;
            background-color: rgba(25, 135, 84, 0.8);
            border-color: #198754;
            border-radius: 50%;
            width: 3em;
            height: 3em;
            line-height: 3em;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container pb-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_video_index') }}">Videos</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ video.title }}</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div>
                            <h1 class="fw-bold h2 mb-1">{{ video.title }}</h1>
                            <p class="text-muted mb-0">Erstellt am {{ video.createdAt|date('d.m.Y H:i') }}</p>
                        </div>
                        <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary border border-primary px-3 py-2">
                            {{ video.status.value|upper }}
                        </span>
                    </div>

                    {% if video.youtubeUrl %}
                        <div class="mb-4">
                            <label class="small text-muted fw-bold text-uppercase mb-2">YouTube Link</label>
                            <div class="d-flex align-items-center bg-light p-3 rounded-3 border">
                                <i class="fab fa-youtube text-danger me-3 fa-lg"></i>
                                <a href="{{ video.youtubeUrl }}" target="_blank" class="text-decoration-none text-dark fw-medium">{{ video.youtubeUrl }}</a>
                            </div>
                        </div>
                    {% endif %}

                    <div class="mb-4">
                        <label class="small text-muted fw-bold text-uppercase mb-2">Analyse Fortschritt</label>
                        <div class="bg-light p-4 rounded-3 border">
                            {{ component('VideoProgressBar', { video: video }) }}
                        </div>
                    </div>

                    {% if video.jellyfinPath %}
                        <div class="alert alert-success border-0 shadow-sm p-4 mb-4">
                            <h6 class="fw-bold mb-3"><i class="fas fa-play-circle me-2"></i> Jellyfin Stream (Vorschau)</h6>
                            <div class="bg-black rounded-3 overflow-hidden shadow mb-3">
                                <video id="jellyfin-player" class="video-js vjs-big-play-centered vjs-16-9" controls preload="auto" data-setup='{"nativeControlsForTouch": false}' style="max-height: 70vh;">
                                    {% if video.jellyfinItemId %}
                                        <source src="{{ jellyfin_host }}/Videos/{{ video.jellyfinItemId }}/stream?static=true&api_key={{ jellyfin_api_key }}" type="video/mp4">
                                        <source src="{{ jellyfin_host }}/Videos/{{ video.jellyfinItemId }}/master.m3u8?api_key={{ jellyfin_api_key }}" type="application/x-mpegURL">
                                    {% else %}
                                        <source src="{{ jellyfin_host }}/Videos/ActiveStream?path={{ video.jellyfinPath|url_encode }}&api_key={{ jellyfin_api_key }}&static=true" type="video/mp4">
                                    {% endif %}
                                    <p class="vjs-no-js">
                                        To view this video please enable JavaScript, and consider upgrading to a
                                        web browser that <a href="https://videojs.com/html5-video-support/" target="_blank">supports HTML5 video</a>
                                    </p>
                                </video>
                            </div>
                            <div id="player-error-message" class="alert alert-warning mt-2 d-none">
                                <i class="fas fa-exclamation-circle me-2"></i> Wiedergabe-Fehler: <span class="error-details"></span>
                            </div>
                            <div class="mt-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <div class="small text-muted">
                                    <i class="fas fa-info-circle me-1"></i> Video wird direkt von Jellyfin gestreamt.
                                    {% if not video.jellyfinItemId %}
                                        <br><span class="text-warning"><i class="fas fa-sync fa-spin me-1"></i> Warte auf Item-ID von Jellyfin... (Seite eventuell neu laden)</span>
                                    {% endif %}
                                </div>
                                <div class="d-flex gap-2">
                                    {% if video.jellyfinItemId %}
                                        <a href="{{ jellyfin_host }}/web/index.html#!/details?id={{ video.jellyfinItemId }}" target="_blank" class="btn btn-sm btn-outline-success">
                                            <i class="fas fa-external-link-alt me-1"></i> In Jellyfin öffnen
                                        </a>
                                    {% endif %}
                                </div>
                            </div>

                            {% if video.chapters|length > 0 %}
                                <div class="mt-4">
                                    <h6 class="fw-bold mb-3 small text-uppercase text-muted"><i class="fas fa-bookmark me-2"></i> Kapitel / Szenen</h6>
                                    <div class="d-flex flex-wrap gap-2">
                                        {% for chapter in video.chapters %}
                                            <button class="btn btn-sm btn-light border jump-to-time" data-time="{{ (chapter.startFrame / video.fps)|default(chapter.startFrame / 25) }}">
                                                <i class="fas fa-step-forward me-1"></i> {{ chapter.title ?: 'Szene ' ~ loop.index }}
                                            </button>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    {% endif %}

                    {% if video.errorMessage %}
                        <div class="alert alert-danger border-0 shadow-sm d-flex align-items-start p-4">
                            <i class="fas fa-exclamation-triangle mt-1 me-3 fa-lg"></i>
                            <div>
                                <h5 class="alert-heading fw-bold mb-1">Analyse fehlgeschlagen</h5>
                                <p class="mb-0 font-monospace small">{{ video.errorMessage }}</p>
                                <hr>
                                <div class="d-flex gap-2 mt-3">
                                    <a href="{{ path('app_video_trigger', {id: video.id, step: 'reset'}) }}" class="btn btn-sm btn-outline-danger">Analyse zurücksetzen</a>
                                </div>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-transparent border-bottom p-4">
                    <h5 class="fw-bold mb-0">Pipeline Schritte</h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        {% set steps = [
                            {'id': 'download', 'name': 'Video Download', 'trigger': 'download', 'ts': video.downloadedAt, 'dur': video.downloadDuration, 'est': null, 'icon': 'download', 'status': video.downloadedAt ? 'done' : (video.status.value == 'downloading' ? 'active' : 'pending')},
                            {'id': 'convert', 'name': 'Konvertierung', 'trigger': 'convert', 'ts': video.convertedAt, 'dur': video.conversionDuration, 'est': video.estimatedConversionDuration, 'icon': 'sync', 'status': video.convertedAt ? 'done' : (video.status.value == 'converting' ? 'active' : 'pending')},
                            {'id': 'scenes', 'name': 'Szenenerkennung', 'trigger': 'scenes', 'ts': video.scenesDetectedAt, 'dur': video.sceneDetectionDuration, 'est': video.estimatedSceneDetectionDuration, 'icon': 'cut', 'status': video.scenesDetectedAt ? 'done' : (video.status.value == 'scene_detection' ? 'active' : 'pending')},
                            {'id': 'splitting', 'name': 'Frame Extraktion', 'trigger': 'split', 'ts': video.framesExtractedAt, 'dur': video.frameExtractionDuration, 'est': video.estimatedFrameExtractionDuration, 'icon': 'film', 'status': video.framesExtractedAt ? 'done' : (video.status.value == 'splitting' ? 'active' : 'pending')},
                            {'id': 'analysis', 'name': 'Gesichtsanalyse', 'trigger': null, 'ts': video.facesAnalyzedAt, 'dur': video.faceAnalysisDuration, 'est': video.estimatedFaceAnalysisDuration, 'icon': 'user-search', 'status': video.facesAnalyzedAt ? 'done' : (video.status.value == 'analyzing_faces' ? 'active' : 'pending')},
                            {'id': 'refine_extract', 'name': 'Verfeinerung: Extraktion', 'trigger': 'refine', 'ts': video.refiningExtractionFinishedAt, 'dur': video.refiningExtractionDuration, 'est': null, 'icon': 'search-plus', 'status': video.refiningExtractionFinishedAt ? 'done' : (video.status.value == 'refining_extraction' ? 'active' : 'pending')},
                            {'id': 'refine_analyze', 'name': 'Verfeinerung: Analyse', 'trigger': null, 'ts': video.refiningAnalysisFinishedAt, 'dur': video.refiningAnalysisDuration, 'est': null, 'icon': 'microscope', 'status': video.refiningAnalysisFinishedAt ? 'done' : (video.status.value == 'refining_analysis' ? 'active' : 'pending')},
                            {'id': 'merge_scenes', 'name': 'Szenen Zusammenführen', 'trigger': null, 'ts': video.mergingScenesAt, 'dur': video.mergingScenesDuration, 'est': null, 'icon': 'object-group', 'status': video.mergingScenesAt ? 'done' : (video.status.value == 'merging_scenes' ? 'active' : 'pending')},
                            {'id': 'optimize', 'name': 'MP4 Optimierung', 'trigger': 'optimize', 'ts': video.convertedAt, 'dur': null, 'est': null, 'icon': 'magic', 'status': video.status.value == 'optimizing' ? 'active' : (video.convertedAt and video.localPath and video.localPath ends with '.mp4' ? 'done' : 'pending')},
                            {'id': 'complete', 'name': 'Abschluss', 'trigger': null, 'ts': video.completedAt, 'dur': null, 'est': null, 'icon': 'check-double', 'status': video.completedAt ? 'done' : 'pending'}
                        ] %}

                        {% for step in steps %}
                            <div class="list-group-item p-4 d-flex align-items-center justify-content-between {% if step.status == 'active' %}bg-primary bg-opacity-10{% endif %}">
                                <div class="d-flex align-items-center flex-grow-1">
                                    <div class="me-4 d-flex align-items-center justify-content-center rounded-circle 
                                        {% if step.status == 'done' %}bg-success text-white
                                        {% elseif step.status == 'active' %}bg-primary text-white
                                        {% else %}bg-light text-muted{% endif %}" 
                                        style="width: 48px; height: 48px;">
                                        {% if step.status == 'done' %}
                                            <i class="fas fa-check"></i>
                                        {% else %}
                                            <i class="fas fa-{{ step.icon }}"></i>
                                        {% endif %}
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h6 class="fw-bold mb-1">{{ step.name }}</h6>
                                                <p class="small text-muted mb-0">
                                                    {% if step.status == 'done' %}
                                                        Abgeschlossen am {{ step.ts|date('H:i:s') }}
                                                        {% if step.dur %} (Dauer: {{ step.dur }}s){% endif %}
                                                    {% elseif step.status == 'active' %}
                                                        In Bearbeitung... 
                                                        {% if step.est %} (~{{ (step.est / 60)|round(0, 'floor') }}:{{ (step.est % 60)|format('%02d') }} min geschätzt){% endif %}
                                                    {% else %}
                                                        Wartet auf Start
                                                        {% if step.est %} (Geschätzt: ~{{ (step.est / 60)|round(0, 'floor') }}:{{ (step.est % 60)|format('%02d') }} min){% endif %}
                                                    {% endif %}
                                                </p>
                                            </div>
                                            {% if step.trigger and video.localPath %}
                                                <a href="{{ path('app_video_trigger', {id: video.id, step: step.trigger}) }}" 
                                                   class="btn btn-xs btn-outline-secondary rounded-pill" 
                                                   title="Ab hier neu starten">
                                                    <i class="fas fa-redo-alt me-1"></i> Neustart
                                                </a>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                                {% if step.status == 'active' %}
                                    <div class="spinner-border spinner-border-sm text-primary ms-3" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-transparent border-bottom p-4">
                    <h5 class="fw-bold mb-0">Aktionen</h5>
                </div>
                <div class="card-body p-4">
                    <div class="d-grid gap-2">
                        <a href="{{ path('video_timeline', {id: video.id}) }}" class="btn btn-outline-primary rounded-pill mb-2">
                            <i class="fas fa-chart-line me-2"></i> Timeline anzeigen
                        </a>
                        <hr>
                        <h6 class="small text-muted fw-bold text-uppercase mb-3">Jellyfin Integration</h6>
                        {% if video.status.value == 'completed' %}
                            <form action="{{ path('app_jellyfin_export', {id: video.id}) }}" method="post">
                                <input type="hidden" name="video_id" value="{{ video.id }}">
                                <p class="small text-muted mb-2">Exportiere dieses Video in deine Jellyfin-Mediathek.</p>
                                <button type="submit" class="btn btn-primary w-100 rounded-pill" {{ not video.localPath ? 'disabled' }}>
                                    <i class="fas fa-share-square me-2"></i> Zu Jellyfin exportieren
                                </button>
                                {% if not video.localPath %}
                                    <div class="alert alert-warning small mt-2 py-1 px-2 border-0">
                                        <i class="fas fa-exclamation-circle me-1"></i> Lokale Datei wurde bereits gelöscht. Export nicht möglich.
                                    </div>
                                {% endif %}
                            </form>
                        {% else %}
                            <p class="small text-muted">Export verfügbar, sobald die Analyse abgeschlossen ist.</p>
                        {% endif %}
                        <hr>
                        <a href="{{ path('app_video_trigger', {id: video.id, step: 'reset'}) }}"
                           class="btn btn-sm btn-light border text-danger d-flex justify-content-between align-items-center mb-2"
                           onclick="return confirm('Möchtest du wirklich alle erkannten Szenen und Personen für dieses Video löschen?')">
                            <span><i class="fas fa-undo me-2"></i> Analyse zurücksetzen</span>
                            <i class="fas fa-chevron-right small opacity-50"></i>
                        </a>
                        <a href="{{ path('app_video_trigger', {id: video.id, step: 'delete'}) }}"
                           class="btn btn-sm btn-outline-danger d-flex justify-content-between align-items-center"
                           onclick="return confirm('Möchtest du wirklich die lokale Videodatei und alle temporären Frames löschen? Die Analyseergebnisse bleiben erhalten.')">
                            <span><i class="fas fa-trash-alt me-2"></i> Lokale Dateien löschen</span>
                            <i class="fas fa-chevron-right small opacity-50"></i>
                        </a>
                    </div>
                </div>
            </div>

            {% if video.localPath %}
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-transparent border-bottom p-4">
                        <h5 class="fw-bold mb-0">Datei-Info</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label class="small text-muted fw-bold text-uppercase mb-1">Dateiname</label>
                            <div class="small text-truncate" title="{{ video.localPath }}">{{ video.localPath|split('/')|last }}</div>
                        </div>
                        <div>
                            <label class="small text-muted fw-bold text-uppercase mb-1">Pfad</label>
                            <code class="d-block bg-light p-2 rounded small text-break" style="font-size: 0.7rem;">{{ video.localPath }}</code>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://vjs.zencdn.net/8.10.0/video.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            if (document.getElementById('jellyfin-player')) {
                const player = videojs('jellyfin-player', {
                    aspectRatio: '16:9',
                    playbackRates: [0.5, 1, 1.5, 2],
                    controlBar: {
                        children: [
                            'playToggle',
                            'volumePanel',
                            'currentTimeDisplay',
                            'timeDivider',
                            'durationDisplay',
                            'progressControl',
                            'liveDisplay',
                            'remainingTimeDisplay',
                            'playbackRateMenuButton',
                            'chaptersButton',
                            'descriptionsButton',
                            'subsCapsButton',
                            'audioTrackButton',
                            'fullscreenToggle'
                        ]
                    }
                });

                player.on('error', function() {
                    const error = player.error();
                    const errorDisplay = document.getElementById('player-error-message');
                    if (errorDisplay) {
                        errorDisplay.classList.remove('d-none');
                        errorDisplay.querySelector('.error-details').textContent = error.message + ' (Code: ' + error.code + ')';
                    }
                });

                // Check if video is playable, otherwise try switching to HLS
                player.ready(function() {
                    console.log('Video.js Player is ready');
                    
                    const checkAndJump = function() {
                        const urlParams = new URLSearchParams(window.location.search);
                        const startTime = urlParams.get('t');
                        if (startTime) {
                            const time = parseFloat(startTime);
                            if (!isNaN(time)) {
                                console.log('Jumping to time from URL:', time);
                                player.currentTime(time);
                                player.play();
                            }
                        }
                    };

                    // Try immediately
                    checkAndJump();

                    // Also try on loadedmetadata as it's more reliable for some browsers
                    player.on('loadedmetadata', checkAndJump);
                });

                // Jump to time functionality
                document.querySelectorAll('.jump-to-time').forEach(button => {
                    button.addEventListener('click', function() {
                        const time = parseFloat(this.getAttribute('data-time'));
                        player.currentTime(time);
                        player.play();
                        
                        // Scroll player into view
                        document.getElementById('jellyfin-player').scrollIntoView({ behavior: 'smooth', block: 'center' });
                    });
                });
            }
        });
    </script>
{% endblock %}
